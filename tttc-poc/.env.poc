# ==============================================================================
# .env.poc — Variáveis de ambiente para a PoC TRL 3 (modo local, sem cloud)
#
# Uso: docker compose --env-file .env.poc up
# ATENÇÃO: Este arquivo NÃO contém segredos reais. É seguro versionar.
# ==============================================================================

# ------------------------------------------------------------------------------
# PYSERVER (Python FastAPI — pipeline LLM com Ollama)
# ------------------------------------------------------------------------------

# Ativa o modo Ollama no pyserver (já é o padrão, mas explicitado)
USE_OLLAMA=true

# URL do container Ollama dentro da rede Docker Compose
OLLAMA_BASE_URL=http://ollama:11434

# Modelo padrão — llama3.2 está no MODEL_MAPPING do ollama_config.py
OLLAMA_DEFAULT_MODEL=llama3.2:latest

# Porta do pyserver
PORT=8000

# ------------------------------------------------------------------------------
# EXPRESS-SERVER (Node.js — orquestrador de pipeline e API REST)
# ------------------------------------------------------------------------------

NODE_ENV=development

# Qualquer valor não-vazio satisfaz a validação Zod; o pyserver usa Ollama
OPENAI_API_KEY=local-ollama-no-key-needed

# URL do pyserver dentro da rede Docker Compose
PYSERVER_URL=http://pyserver:8000

# URL do next-client para CORS e redirecionamentos
CLIENT_BASE_URL=http://localhost:3000

# Redis para fila BullMQ (adicionado ao docker-compose.poc.yml no Step 3)
REDIS_URL=redis://redis:6379

# Ativa armazenamento local no express-server (patches em tttc-poc/patches/ aplicados no Step 3)
USE_LOCAL_STORAGE=true

# Bucket GCS — stub para PoC (ignorado com USE_LOCAL_STORAGE=true)
GCLOUD_STORAGE_BUCKET=poc-local-bucket

# Credenciais GCS — stub (ignoradas com USE_LOCAL_STORAGE=true)
GOOGLE_CREDENTIALS_

# Credenciais Firebase codificadas em base64 — stub (mesmo valor que GCS para PoC)
FIREBASE_CREDENTIALS_

# Firebase Realtime Database — stub URL (não será chamada com o patch local)
FIREBASE_DATABASE_URL=https://poc-local-default-rtdb.firebaseio.com/

# ------------------------------------------------------------------------------
# NEXT-CLIENT (Next.js — frontend)
# ------------------------------------------------------------------------------

# URL do express-server vista pelo next-client (dentro da rede Docker Compose)
PIPELINE_EXPRESS_URL=http://express-server:8080

# Configuração Firebase do cliente — stubs para PoC (auth desativada pelo patch)
NEXT_PUBLIC_FIREBASE_API_KEY=poc-local-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=poc-local.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=poc-local
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=poc-local.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:poc000000000000

# ==============================================================================
# NOTA: express-server inicializa Firebase e GCS no carregamento do módulo.
# Para a PoC, patches em tttc-poc/patches/ substituem Firebase.ts e storage.ts
# por implementações locais, montadas via Docker volume no Step 3.
# ==============================================================================
